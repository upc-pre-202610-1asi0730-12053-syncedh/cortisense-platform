                +Id: int
                +OrganizationId: int
                +PlanId: int
                +Status: ECheckoutSessionStatus
                +StripeSessionId: string
                +StripeSessionUrl: string
            }

            enum EBillingPeriod <<ValueObject>> {
                Monthly
                Annual
            }

            enum ESubscriptionStatus <<ValueObject>> {
                Pending
                Active
                Cancelled
                Expired
            }

            enum ECheckoutSessionStatus <<ValueObject>> {
                Pending
                Completed
                Expired
            }

            enum ESupportLevel <<ValueObject>> {
                Basic
                Priority
                Dedicated
            }

            interface ISubscriptionCommandService {
                +Handle(command: CreateSubscriptionCommand, ct: CancellationToken): Task<Subscription>
                +Handle(command: UpdateSubscriptionCommand, ct: CancellationToken): Task<Subscription?>
                +Handle(command: CancelSubscriptionCommand, ct: CancellationToken): Task<Subscription?>
            }
            interface ICheckoutSessionCommandService {
                +Handle(command: CreateCheckoutSessionCommand, ct: CancellationToken): Task<CheckoutSession>
            }
            interface IPlanQueryService {
                +Handle(query: GetAllPlansQuery, ct: CancellationToken): Task<IEnumerable<Plan>>
                +Handle(query: GetPlanByIdQuery, ct: CancellationToken): Task<Plan?>
            }
        }

        package "Interfaces" as SubInterfaces {
            class PlansController {
                +PlansController(qrySvc: IPlanQueryService)
                +GetAll(ct): Task<IActionResult>
                +GetById(id: int, ct): Task<IActionResult>
            }
            class SubscriptionsController {
                +SubscriptionsController(cmdSvc: ISubscriptionCommandService, qrySvc: ISubscriptionQueryService)
                +Create(resource, ct): Task<IActionResult>
                +GetAll(ct): Task<IActionResult>
                +Update(id: int, resource, ct): Task<IActionResult>
            }
            class CheckoutSessionsController {
                +CheckoutSessionsController(cmdSvc: ICheckoutSessionCommandService, qrySvc: ICheckoutSessionQueryService)
                +Create(resource, ct): Task<IActionResult>
                +GetByOrganizationId(organizationId: int, ct): Task<IActionResult>
            }
            class BillingController {
                +BillingController(cmdSvc: ISubscriptionCommandService, stripeSvc: IStripeBillingService)
                +HandleWebhook(ct): Task<IActionResult>
            }
        }

        PlansController ..> IPlanQueryService : dependency
        SubscriptionsController ..> ISubscriptionCommandService : dependency
        CheckoutSessionsController ..> ICheckoutSessionCommandService : dependency
        BillingController ..> ISubscriptionCommandService : dependency
        Subscription --> Plan : references (by PlanId)
    }


    ' =========================================================
    ' CROSS-BOUNDARY RELATIONSHIPS
    ' =========================================================

    ' All BCs repositories extend IBaseRepository from Shared
    IUserRepository ...|> IBaseRepository : extends
    IOrganizationRepository ...|> IBaseRepository : extends
    IInvitationRepository ...|> IBaseRepository : extends

    ' Application Layer dependencies on Shared
    UserCommandService ..> IUnitOfWork : dependency
    OrganizationCommandService ..> IUnitOfWork : dependency
    InvitationCommandService ..> IUnitOfWork : dependency
    VitalSignReadingCommandService ..> IUnitOfWork : dependency
    RiskAssessmentCommandService ..> IUnitOfWork : dependency

    ' Infrastructure dependencies on AppDbContext
    UserRepository ..> AppDbContext : dependency
    OrganizationRepository ..> AppDbContext : dependency
    InvitationRepository ..> AppDbContext : dependency

    ' Cross-BC: Clinical Risk -> Audit
    VitalSignReadingCommandService ..> IAuditLogCommandService : dependency
    RiskAssessmentCommandService ..> IAuditLogCommandService : dependency

    ' Cross-BC: Shift Coord -> Audit
    ' (via AuditLogCommandService injected into ShiftRecord command services)

    ' IAuditableEntity applied to all aggregates
    User ..|> IAuditableEntity : implements
    Organization ..|> IAuditableEntity : implements
    Invitation ..|> IAuditableEntity : implements
    VitalSignReading ..|> IAuditableEntity : implements
    VitalSignAnomaly ..|> IAuditableEntity : implements
    ClinicalAlert ..|> IAuditableEntity : implements
    RiskAssessment ..|> IAuditableEntity : implements
    CareTeam ..|> IAuditableEntity : implements
    TeamMember ..|> IAuditableEntity : implements
    ShiftRecord ..|> IAuditableEntity : implements
    WorkArea ..|> IAuditableEntity : implements
    Specialty ..|> IAuditableEntity : implements
    RecoveryPlan ..|> IAuditableEntity : implements
    AuditLog ..|> IAuditableEntity : implements
    Plan ..|> IAuditableEntity : implements
    Subscription ..|> IAuditableEntity : implements
    CheckoutSession ..|> IAuditableEntity : implements

@enduml
