@startuml SyncedHealth.Center.Platform Class Diagram

    title
        SyncedHealth.Center.Platform
        Class Diagram
        IAM, Clinical Risk, Shift Coordination, Staff Recovery, Audit & Compliance, Subscription, Shared
    end title

    ' =========================================================
    ' SHARED BOUNDED CONTEXT
    ' =========================================================
    package "Shared Bounded Context" as Shared {
        package "Domain" as SharedDomain {
            interface IBaseRepository<TEntity> {
                +AddAsync(entity: TEntity, ct: CancellationToken): Task
                +FindByIdAsync(id: int, ct: CancellationToken): Task<TEntity?>
                +Update(entity: TEntity): void
                +Remove(entity: TEntity): void
                +ListAsync(ct: CancellationToken): Task<IEnumerable<TEntity>>
            }

            interface IUnitOfWork {
                +CompleteAsync(ct: CancellationToken): Task
            }

            interface IAuditableEntity <<Entity>> {
                +CreatedAt: DateTimeOffset?
                +UpdatedAt: DateTimeOffset?
            }
        }

        package "Infrastructure" as SharedInfra {
            class AppDbContext {
                +AppDbContext(options: DbContextOptions<AppDbContext>)
                +SaveChangesAsync(ct: CancellationToken): Task<int>
            }

            class BaseRepository<TEntity> implements IBaseRepository {
                +BaseRepository(context: AppDbContext)
                +AddAsync(entity: TEntity, ct: CancellationToken): Task
                +FindByIdAsync(id: int, ct: CancellationToken): Task<TEntity?>
                +Update(entity: TEntity): void
                +Remove(entity: TEntity): void
                +ListAsync(ct: CancellationToken): Task<IEnumerable<TEntity>>
            }

            class UnitOfWork implements IUnitOfWork {
                +UnitOfWork(context: AppDbContext)
                +CompleteAsync(ct: CancellationToken): Task
            }

            class AuditableEntityInterceptor {
                +SavingChangesAsync(eventData, result, ct): ValueTask<InterceptionResult<int>>
            }
        }

        BaseRepository ..> AppDbContext : dependency
        UnitOfWork ..> AppDbContext : dependency
    }

